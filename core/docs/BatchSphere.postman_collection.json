        },
        "url": {
          "raw": "{{baseUrl}}/api/grns/{{grnId}}/receive",
          "host": ["{{baseUrl}}"],
          "path": ["api", "grns", "{{grnId}}", "receive"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "var json = pm.response.json();",
              "pm.test('GRN is received', function () { pm.expect(json.status).to.eql('RECEIVED'); });"
            ]
          }
        }
