  "item": [
    {
      "name": "1. Create Supplier",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"supplierCode\": \"SUP-001\",\n  \"supplierName\": \"Acme Chemicals\",\n  \"contactPerson\": \"Ravi Kumar\",\n  \"email\": \"supplier@acme.com\",\n  \"phone\": \"9876543210\",\n  \"createdBy\": \"admin\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/suppliers",
          "host": ["{{baseUrl}}"],
          "path": ["api", "suppliers"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "var json = pm.response.json();",
              "pm.collectionVariables.set('supplierId', json.id);"
            ]
          }
        }
      ]
    },
